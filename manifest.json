{
  "manifest_version": 3,
  "name": "__MSG_tool_name__",
  "description": "__MSG_tool_description__",
  "author": "__MSG_tool_author__",
  "version": "0.11.0",
  "default_locale": "zh_TW",
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "js": [
        "content/turndown.browser.umd.js",
        "content/content-script.js"
      ],
      "matches": [
        "https://notebooklm.google.com/*",
        "https://*.scf.usercontent.goog/*"
      ],
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ],
  "host_permissions": [
    "https://notebooklm.google.com/*"
  ],
  "permissions": [
    "notifications",
    "contextMenus",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  }
}
